{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>home-operations/renovate-config"],
  customManagers: [
    {
      customType: "regex",
      description: ["Process Helm-sourced charts"],
      managerFilePatterns: ["/(^|/)metadata\\.ya?ml$/"],
      matchStrings: [
        "artifactName:\\s+(?<artifactName>\\S+)\\s+source:\\s+helm:\\s+registry:\\s+(?<registryUrl>\\S+)\\s+version:\\s+(?<currentValue>\\S+)(?:\\s+chart:\\s+(?<chart>\\S+))?",
      ],
      datasourceTemplate: "helm",
      depNameTemplate: "{{#if chart}}{{chart}}{{else}}{{artifactName}}{{/if}}",
    },
    {
      customType: "regex",
      description: ["Process git-sourced charts"],
      managerFilePatterns: ["/(^|/)metadata\\.ya?ml$/"],
      matchStrings: [
        "source:\\s+git:\\s+repository:\\s+(?<depName>\\S+)\\s+path:\\s+\\S+\\s+tag:\\s+(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "git-tags",
      extractVersionTemplate: "^v?(?<version>.+)$",
    },
  ],
  packageRules: [
    {
      description: "Auto-merge Helm Charts",
      matchDatasources: ["helm"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["major", "minor", "patch"],
      ignoreTests: false,
    },
  ],
}
